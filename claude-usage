#!/usr/bin/env python3
"""Check whether Claude subscription usage is available.

Reads the Claude Code OAuth token from the macOS Keychain and queries
Anthropic's usage endpoint (undocumented; same data the /usage command shows).

Commands:
  status   (default) live-updating view in a terminal; --once for a snapshot
  check    print true/false; exit 0 = available, 1 = limited, 2 = unknown
  notify   for launchd: notify on limit-reached / limit-reset transitions
  anchor   send one tiny cheapest-model message to open a 5-hour session
           window; by default only if none is open, --force sends always
  sessions list recent Claude Code sessions + time since last activity
           (reads local transcripts only — costs nothing)
  keepalive send a stub to --session-id to refresh its prompt cache, only
           if idle > --stale-after seconds (skip if recently active)
  raw      dump the raw endpoint response

Windows reported: session (5h), weekly (all models), plus any model-scoped
weekly window the account has (e.g. fable).
"""

import argparse
import json
import shutil
import signal
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path

KEYCHAIN_SERVICE = "Claude Code-credentials"
USAGE_URL = "https://api.anthropic.com/api/oauth/usage"
BETA_HEADER = "oauth-2025-04-20"
STATE_DIR = Path.home() / ".local/state/claude-usage"
STATE_FILE = STATE_DIR / "state.json"
CACHE_FILE = STATE_DIR / "usage-cache.json"
# Serve a fresh-enough cached reading without touching the network — collapses
# the app + watcher + live-view polls into shared reads.
CACHE_TTL_SECONDS = 90
# On a failed read, still show a cache this old (marked stale) rather than blank.
CACHE_STALE_SECONDS = 45 * 60
# After a 429, all invocations stop hitting the network for this long so the
# endpoint can recover; cached data is served in the meantime.
BACKOFF_SECONDS = 5 * 60
# A probe spends a sliver of real subscription usage, so rate-limit both the
# token-refresh path and the auto-anchor path.
REFRESH_GUARD_SECONDS = 30 * 60
ANCHOR_GUARD_SECONDS = 30 * 60
# Prompt-cache lifetime we assume for keep-alive. Past this a session is cold and
# we refuse to warm it — resurrecting a dead cache is a full re-read for nothing.
CACHE_WARM_TTL = 60 * 60
ANCHOR_LOG = STATE_DIR / "anchor.log"
COST_CACHE = STATE_DIR / "cost-cache.json"
# Published $/1M (input, output). Subscription users don't pay these, but the
# weighting makes per-session consumption comparable across models.
MODEL_RATES = {"fable": (10.0, 50.0), "opus": (5.0, 25.0),
               "sonnet": (3.0, 15.0), "haiku": (1.0, 5.0)}


def _rates_for(model):
    m = (model or "").lower()
    for key, r in MODEL_RATES.items():
        if key in m:
            return r
    return MODEL_RATES["opus"]  # sane default for unknown ids
# Cheapest model, one-word prompt => about as close to a no-op request as exists.
PROBE_ARGS = ["-p", "reply with just: ok", "--model", "haiku"]
# Run the probe in a dedicated empty local dir so Claude Code never scans the
# home tree / cloud folders and trips macOS folder-access (TCC) prompts.
PROBE_CWD = STATE_DIR / "probe-cwd"


def now_utc():
    return datetime.now(timezone.utc)


def load_state():
    try:
        return json.loads(STATE_FILE.read_text())
    except Exception:
        return {}


def save_state(state):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state, indent=2))


def read_keychain_creds():
    try:
        out = subprocess.run(
            ["security", "find-generic-password", "-s", KEYCHAIN_SERVICE, "-w"],
            capture_output=True, text=True, timeout=15,
        )
    except Exception:
        return None
    if out.returncode != 0:
        return None
    try:
        return json.loads(out.stdout.strip()).get("claudeAiOauth")
    except json.JSONDecodeError:
        return None


def token_expired(creds):
    exp = creds.get("expiresAt")
    return bool(exp) and exp / 1000 <= now_utc().timestamp()


def find_claude_cli():
    cli = shutil.which("claude")
    if cli:
        return cli
    fallback = Path.home() / ".local/bin/claude"
    return str(fallback) if fallback.exists() else None


def run_claude_probe():
    """One tiny headless call. It counts as normal subscription usage, so it both
    refreshes the Keychain token and opens a 5-hour session window if none is open.
    Returns (ok, message)."""
    cli = find_claude_cli()
    if not cli:
        return False, "claude CLI not found"
    try:
        PROBE_CWD.mkdir(parents=True, exist_ok=True)
    except Exception:
        pass
    try:
        proc = subprocess.run(
            [cli, *PROBE_ARGS],
            stdout=subprocess.DEVNULL, stderr=subprocess.PIPE, timeout=180,
            cwd=str(PROBE_CWD),
        )
    except subprocess.TimeoutExpired:
        return False, "probe timed out"
    except Exception as e:
        return False, f"probe failed: {e}"
    if proc.returncode != 0:
        err = (proc.stderr or b"").decode("utf-8", "replace").strip()
        return False, err or f"probe exit {proc.returncode}"
    return True, "ok"


def refresh_via_cli(state):
    """Trigger Claude Code itself to refresh + persist the Keychain token."""
    if now_utc().timestamp() - state.get("last_refresh_attempt", 0) < REFRESH_GUARD_SECONDS:
        return False
    state["last_refresh_attempt"] = now_utc().timestamp()
    save_state(state)
    ok, _ = run_claude_probe()
    return ok


def load_cache():
    try:
        obj = json.loads(CACHE_FILE.read_text())
        return obj.get("raw"), float(obj.get("fetched_at", 0))
    except Exception:
        return None, 0.0


def save_cache(raw):
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        CACHE_FILE.write_text(json.dumps({"fetched_at": now_utc().timestamp(), "raw": raw}))
    except Exception:
        pass


def fetch_usage(token):
    req = urllib.request.Request(USAGE_URL, headers={
        "Authorization": f"Bearer {token}",
        "anthropic-beta": BETA_HEADER,
        "User-Agent": "claude-usage/1.0",
    })
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.load(resp), resp.status
    except urllib.error.HTTPError as e:
        return None, e.code
    except Exception:
        return None, 0


def get_usage(auto_refresh, allow_cache=True):
    """Returns (raw_response_or_None, token_status, state).

    token_status: "ok" (fresh network read), "cached" (recent cache, no network),
    "stale" (network unavailable, showing older cache), or an error string.
    """
    state = load_state()
    cached_raw, cached_at = load_cache()
    age = now_utc().timestamp() - cached_at

    def stale_or(err_status):
        if cached_raw is not None and age < CACHE_STALE_SECONDS:
            return cached_raw, "stale", state
        return None, err_status, state

    # Serve a fresh-enough cache without touching the network.
    if allow_cache and cached_raw is not None and age < CACHE_TTL_SECONDS:
        return cached_raw, "cached", state

    # Respect an active backoff after a recent 429.
    if now_utc().timestamp() < state.get("backoff_until", 0):
        return stale_or(f"backing off {int(state['backoff_until'] - now_utc().timestamp())}s")

    creds = read_keychain_creds()
    if not creds or not creds.get("accessToken"):
        return stale_or("no_credentials")

    if token_expired(creds) and auto_refresh and refresh_via_cli(state):
        creds = read_keychain_creds() or creds
    raw, code = fetch_usage(creds["accessToken"])
    if raw is None and code == 401 and auto_refresh and refresh_via_cli(state):
        creds = read_keychain_creds() or creds
        raw, code = fetch_usage(creds["accessToken"])

    if raw is not None:
        save_cache(raw)
        if state.get("backoff_until"):
            state["backoff_until"] = 0
            save_state(state)
        return raw, "ok", state

    if code == 429:
        state["backoff_until"] = now_utc().timestamp() + BACKOFF_SECONDS
        save_state(state)
    return stale_or("stale_token" if code == 401 else f"http_error_{code}")


def parse_iso(ts):
    if not ts:
        return None
    try:
        return datetime.fromisoformat(ts)
    except ValueError:
        return None


def normalize(raw):
    """Flatten the response into [{name, percent, severity, resets_at}, ...]."""
    windows = []
    for lim in raw.get("limits") or []:
        name = {"session": "session", "weekly_all": "weekly"}.get(lim.get("kind"))
        if name is None:
            model = ((lim.get("scope") or {}).get("model") or {}).get("display_name")
            name = (model or lim.get("kind") or "scoped").lower()
        windows.append({
            "name": name,
            "percent": lim.get("percent"),
            "severity": lim.get("severity"),
            "resets_at": lim.get("resets_at"),
        })
    if not windows:  # older response shape
        for key, name in (("five_hour", "session"), ("seven_day", "weekly")):
            w = raw.get(key) or {}
            if w.get("utilization") is not None:
                windows.append({
                    "name": name,
                    "percent": w["utilization"],
                    "severity": None,
                    "resets_at": w.get("resets_at"),
                })
    return windows


def is_blocked(window, threshold):
    p = window.get("percent")
    return (p is not None and p >= threshold) or window.get("severity") == "exceeded"


def human_delta(seconds):
    seconds = max(0, int(seconds))
    d, rem = divmod(seconds, 86400)
    h, rem = divmod(rem, 3600)
    m = rem // 60
    if d:
        return f"{d}d {h}h"
    if h:
        return f"{h}h {m:02d}m"
    return f"{m}m"


def format_reset(window):
    rs = parse_iso(window.get("resets_at"))
    if rs is None:
        return "resets unknown"
    delta = (rs - now_utc()).total_seconds()
    local = rs.astimezone()
    stamp = local.strftime("%H:%M") if delta < 86400 else local.strftime("%a %d %b %H:%M")
    return f"resets {stamp} ({human_delta(delta)})"


def build_report(raw, threshold, selected):
    windows = normalize(raw)
    if selected:
        windows = [w for w in windows if w["name"] in selected]
    for w in windows:
        rs = parse_iso(w.get("resets_at"))
        w["left"] = None if w["percent"] is None else max(0, round(100 - w["percent"], 1))
        w["resets_in_seconds"] = None if rs is None else max(0, int((rs - now_utc()).total_seconds()))
        w["blocked"] = is_blocked(w, threshold)
    available = bool(windows) and not any(w["blocked"] for w in windows)
    return windows, available


def fmt_pct(p):
    return "?" if p is None else f"{p:g}%"


BAR_WIDTH = 18


def ansi(s, code):
    return f"\x1b[{code}m{s}\x1b[0m"


def usage_bar(window):
    p = window.get("percent")
    if p is None:
        return "?" * BAR_WIDTH, "2"
    filled = max(0, min(BAR_WIDTH, round(p / 100 * BAR_WIDTH)))
    code = "31" if window.get("blocked") or p >= 90 else ("33" if p >= 70 else "32")
    return "█" * filled + "░" * (BAR_WIDTH - filled), code


def render_live(windows, available, err, fetched_stamp, interval):
    lines = [ansi(f"Claude usage · updated {fetched_stamp} · refreshing every {interval}s · Ctrl-C quits", "2")]
    width = max((len(w["name"]) for w in windows), default=7)
    for w in windows:
        barstr, code = usage_bar(w)
        flag = ansi("  LIMITED", "1;31") if w["blocked"] else ""
        lines.append(
            f"{w['name']:<{width}}  {ansi(barstr, code)}  {fmt_pct(w['percent']):>5} used · "
            f"{fmt_pct(w['left']):>5} left · {format_reset(w)}{flag}")
    if err:
        lines.append(ansi(f"! {err}", "33"))
    if available is not None:
        lines.append("available: " + (ansi("true", "1;32") if available else ansi("false", "1;31")))
    return lines


def run_live(args):
    signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
    interval = max(5, int(args.interval))
    windows, available, err = [], None, None
    fetched_stamp = "…"
    last_fetch = None
    printed = 0
    sys.stdout.write("\x1b[?25l")
    try:
        while True:
            if last_fetch is None or time.monotonic() - last_fetch >= interval:
                raw, token_status, _ = get_usage(args.auto_refresh)
                last_fetch = time.monotonic()
                if raw is None:
                    err = ("token stale — run any `claude` command once, or pass --auto-refresh"
                           if token_status == "stale_token" else f"fetch failed: {token_status}")
                else:
                    err = None
                    fetched_stamp = datetime.now().strftime("%H:%M:%S")
                    windows, available = build_report(raw, args.threshold, args.window)
            lines = render_live(windows, available, err, fetched_stamp, interval)
            if printed:
                sys.stdout.write(f"\x1b[{printed}A")
            for ln in lines:
                sys.stdout.write("\x1b[2K" + ln + "\n")
            printed = len(lines)
            sys.stdout.flush()
            time.sleep(1)
    except KeyboardInterrupt:
        pass
    finally:
        sys.stdout.write("\x1b[?25h")
        sys.stdout.flush()


def notify_mac(message):
    body = message.replace("\\", "\\\\").replace('"', '\\"')
    subprocess.run(
        ["osascript", "-e", f'display notification "{body}" with title "Claude Usage"'],
        capture_output=True, timeout=15,
    )


CLAUDE_PROJECTS = Path.home() / ".claude/projects"
CLAUDE_SESSIONS = Path.home() / ".claude/sessions"


CLAUDE_DESKTOP_SESSIONS = Path.home() / "Library/Application Support/Claude/claude-code-sessions"


def _session_titles():
    """Map a CLI sessionId -> the title Claude Code shows for it.

    Prefers the desktop app's store (~/Library/.../claude-code-sessions), where
    custom /rename titles actually live, joined to CLI transcripts by
    cliSessionId / bridgeSessionIds. Falls back to the CLI's own derived name
    in ~/.claude/sessions/<pid>.json. Returns {sid: (title, source)}."""
    titles = {}

    # 1) CLI derived names (lowest priority) — ~/.claude/sessions/<pid>.json
    if CLAUDE_SESSIONS.is_dir():
        best = {}
        for f in CLAUDE_SESSIONS.glob("*.json"):
            try:
                o = json.loads(f.read_text())
                sid, name, mtime = o.get("sessionId"), o.get("name"), f.stat().st_mtime
            except Exception:
                continue
            if sid and name and (sid not in best or mtime > best[sid]):
                best[sid] = mtime
                titles[sid] = (name, o.get("nameSource") or "derived")

    # 2) Desktop app titles (highest priority) — the custom /rename values
    if CLAUDE_DESKTOP_SESSIONS.is_dir():
        latest = {}
        for f in CLAUDE_DESKTOP_SESSIONS.glob("**/local_*.json"):
            try:
                o = json.loads(f.read_text())
            except Exception:
                continue
            title = o.get("title")
            if not title:
                continue
            ts = o.get("lastActivityAt") or 0
            ids = [o.get("cliSessionId")] + (o.get("bridgeSessionIds") or [])
            for sid in ids:
                if sid and (sid not in latest or ts > latest[sid]):
                    latest[sid] = ts
                    titles[sid] = (title, o.get("titleSource") or "auto")
    return titles


def _session_meta(path):
    """Scan a transcript's tail (newest lines first) and return cwd / branch /
    slug from the most recent line that carries each — some trailing lines
    (summaries, tool results) omit them."""
    try:
        with open(path, "rb") as fh:
            try:
                fh.seek(-131072, 2)
            except OSError:
                fh.seek(0)
            tail = fh.read().decode("utf-8", "replace")
    except OSError:
        return {}
    meta = {}
    for line in reversed(tail.splitlines()):
        line = line.strip()
        if not line.startswith("{"):
            continue
        try:
            o = json.loads(line)
        except json.JSONDecodeError:
            continue
        for k in ("cwd", "gitBranch", "slug"):
            if not meta.get(k) and o.get(k):
                meta[k] = o[k]
        # The last assistant turn is the real "cache was used" moment. File mtime
        # also moves when the desktop app rewrites session state without any
        # request — that must NOT count as warm.
        if "last_active" not in meta and o.get("type") == "assistant":
            rs = parse_iso(o.get("timestamp"))
            if rs:
                meta["last_active"] = rs.timestamp()
        if "cwd" in meta and "gitBranch" in meta and "last_active" in meta:
            break
    return meta


def scan_sessions(max_age_seconds=7200):
    """Recent Claude Code sessions from local transcripts. mtime = last activity
    (fast); the last line carries cwd / branch / slug for a readable label.
    No API calls — reading this costs nothing."""
    out = []
    if not CLAUDE_PROJECTS.is_dir():
        return out
    names = _session_titles()
    now = now_utc().timestamp()
    for f in CLAUDE_PROJECTS.glob("*/*.jsonl"):
        try:
            mtime = f.stat().st_mtime
        except OSError:
            continue
        # mtime >= the last real turn, so it's a safe cheap pre-filter; the
        # accurate age comes from the last assistant turn below.
        if now - mtime > max_age_seconds:
            continue
        meta = _session_meta(f)
        active = meta.get("last_active") or mtime   # accepted turn, not a bare file touch
        age = now - active
        if age > max_age_seconds:
            continue
        cwd = meta.get("cwd")
        named = names.get(f.stem)
        out.append({
            "session_id": f.stem,
            "age_seconds": int(age),
            "last_active": datetime.fromtimestamp(active, timezone.utc).isoformat(),
            "name": named[0] if named else None,
            "name_source": named[1] if named else None,
            "project": Path(cwd).name if cwd else f.parent.name.split("-")[-1],
            "cwd": cwd,
            "branch": meta.get("gitBranch"),
            "slug": meta.get("slug"),
        })
    out.sort(key=lambda s: s["age_seconds"])
    return out


def _parse_since(s):
    """'5h' | '1d' | '1w' | 'all' -> window seconds (None = all time)."""
    s = (s or "1d").strip().lower()
    if s in ("all", "0", ""):
        return None
    units = {"h": 3600, "d": 86400, "w": 604800}
    try:
        return float(s[:-1]) * units[s[-1]]
    except (KeyError, ValueError, IndexError):
        return 86400


def scan_costs(since_seconds):
    """Per-session consumption within a time window, deduped by message id.

    Transcripts log each assistant message several times (streaming rewrites),
    and resumed/forked sessions copy prior history into new files — so summing
    raw usage lines double- or triple-counts. We key each message by its id and
    count it once, and filter by the message's own timestamp for the window."""
    out = []
    if not CLAUDE_PROJECTS.is_dir():
        return out
    now = now_utc().timestamp()
    cut = (now - since_seconds) if since_seconds else 0.0
    seen, per_session = set(), {}
    names = _session_titles()
    for f in CLAUDE_PROJECTS.glob("*/*.jsonl"):
        try:
            mt = f.stat().st_mtime
        except OSError:
            continue
        if since_seconds and mt < cut:   # untouched within the window => no in-window turns
            continue
        try:
            fh = open(f, errors="ignore")
        except OSError:
            continue
        with fh:
            for line in fh:
                if '"usage"' not in line:
                    continue
                try:
                    o = json.loads(line)
                except json.JSONDecodeError:
                    continue
                m = o.get("message", {})
                u = m.get("usage")
                if not isinstance(u, dict):
                    continue
                mid = m.get("id")
                if mid:
                    if mid in seen:
                        continue      # already counted this exact message
                    seen.add(mid)
                if since_seconds:
                    ts = parse_iso(o.get("timestamp"))
                    if ts and ts.timestamp() < cut:
                        continue
                in_rate, out_rate = _rates_for(m.get("model"))
                it = u.get("input_tokens") or 0
                ot = u.get("output_tokens") or 0
                cc = u.get("cache_creation_input_tokens") or 0
                cr = u.get("cache_read_input_tokens") or 0
                cost = (it * in_rate + cc * in_rate * 1.25
                        + cr * in_rate * 0.1 + ot * out_rate) / 1e6
                sid = o.get("sessionId") or f.stem   # credit the owning session, not the fork
                d = per_session.setdefault(sid, {"cost": 0.0, "out": 0, "model": m.get("model")})
                d["cost"] += cost
                d["out"] += ot
    for sid, d in per_session.items():
        named = names.get(sid)
        out.append({
            "session_id": sid,
            "name": named[0] if named else None,
            "cost_usd": round(d["cost"], 2),
            "output_tokens": d["out"],
            "model": d["model"],
        })
    out.sort(key=lambda s: s["cost_usd"], reverse=True)
    return out


def run_keepalive(session_id, stale_after, json_out):
    """Send one tiny stub to a session to refresh its prompt cache — but only if
    it's been idle longer than `stale_after` seconds (skip if recently active,
    so a real message you just sent already did the job).

    The cache only refreshes when the request is actually accepted — a probe
    rejected because you've hit a limit never reaches the model, so it does NOT
    warm the cache. We therefore verify acceptance (exit code + output) before
    reporting success, instead of assuming the send worked.

    Never warms a cold session — once the cache has lapsed there's nothing to
    extend, so warming it would re-read the whole context for zero benefit.

    Exit codes: 0 sent, 2 not found, 3 skipped (still warm), 4 limited
    (rejected — cache NOT refreshed), 5 failed, 6 busy (session open elsewhere),
    7 cold (already expired — deliberately not warmed).
    """
    def done(status, message, code):
        if json_out:
            print(json.dumps({"status": status, "message": message, "session_id": session_id}))
        else:
            print(f"{status}: {message}", file=sys.stderr if code else sys.stdout)
        sys.exit(code)

    matches = list(CLAUDE_PROJECTS.glob(f"*/{session_id}.jsonl"))
    if not matches:
        done("error", f"session {session_id[:8]} not found", 2)
    f = matches[0]
    meta = _session_meta(f)
    active = meta.get("last_active") or f.stat().st_mtime
    age = now_utc().timestamp() - active
    # Already cold: the cache is gone — refuse, even on a manual/forced request.
    if age >= CACHE_WARM_TTL:
        done("cold", f"cold ({int(age // 60)}m idle) — not warming a dead cache", 7)
    if age < stale_after:
        done("skipped", f"active {int(age // 60)}m ago — still warm", 3)
    cwd = meta.get("cwd")
    cli = shutil.which("claude") or str(Path.home() / ".local/bin/claude")
    try:
        proc = subprocess.run(
            [cli, "--resume", session_id, "-p", "reply with just: ok"],
            capture_output=True, text=True, timeout=180,
            cwd=cwd if cwd and Path(cwd).is_dir() else None,
        )
    except Exception as e:
        done("error", f"keepalive failed: {e}", 5)
    raw = ((proc.stdout or "") + "\n" + (proc.stderr or "")).strip()
    blob = raw.lower()
    first = next((ln.strip() for ln in raw.splitlines() if ln.strip()), "")
    # Rejected at the limit: the request never touched the cache — do not claim a refresh.
    if ("hit your" in blob and "limit" in blob) or ("limit" in blob and "reset" in blob):
        done("limited", "not refreshed — usage limit reached", 4)
    # Session already open in the desktop app / another terminal: can't resume it.
    if "in use" in blob or "already" in blob or "being used" in blob or "locked" in blob:
        done("busy", "not refreshed — session is open elsewhere; close it and retry", 6)
    if proc.returncode != 0:
        detail = f" — {first[:120]}" if first else ""
        done("error", f"not refreshed — rejected (exit {proc.returncode}){detail}", 5)
    done("sent", "cache refreshed via accepted stub message", 0)


def main():
    ap = argparse.ArgumentParser(
        description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("command", nargs="?", default="status",
                    choices=["status", "check", "notify", "anchor", "sessions",
                             "keepalive", "cost", "raw"])
    ap.add_argument("--json", action="store_true", help="machine-readable status output")
    ap.add_argument("--threshold", type=float, default=100,
                    help="treat a window as limited at this used %% (default 100)")
    ap.add_argument("--window", action="append", default=None,
                    help="only consider this window (session/weekly/fable); repeatable")
    ap.add_argument("--auto-refresh", action="store_true",
                    help="on stale token, refresh via one tiny headless claude call")
    ap.add_argument("--once", action="store_true",
                    help="print a single snapshot instead of the live view")
    ap.add_argument("--live", action="store_true",
                    help="force the live view even when stdout is not a terminal")
    ap.add_argument("--interval", type=int, default=30,
                    help="live view refresh seconds (default 30, min 5)")
    ap.add_argument("--force", action="store_true",
                    help="for anchor: send the probe even if a window is open")
    ap.add_argument("--session-id", help="for keepalive: which session to refresh")
    ap.add_argument("--stale-after", type=int, default=3300,
                    help="keepalive: only fire if idle longer than this (default 3300s = 55m)")
    ap.add_argument("--max-age", type=int, default=7200,
                    help="sessions: only list sessions active within this many seconds (default 7200)")
    ap.add_argument("--since", default="1d",
                    help="cost window: 5h | 1d | 1w | all (default 1d)")
    args = ap.parse_args()

    if args.command == "cost":
        rows = scan_costs(_parse_since(args.since))
        total = round(sum(r["cost_usd"] for r in rows), 2)
        if args.json:
            print(json.dumps({"sessions": rows, "total_usd": total, "since": args.since}))
        else:
            for r in rows[:20]:
                label = (r["name"] or r["session_id"][:8])[:34]
                share = (r["cost_usd"] / total * 100) if total else 0
                print(f"  {share:5.1f}%  {label:<34} {r['output_tokens'] // 1000}k out")
            print(f"  ── {len(rows)} sessions · since {args.since} "
                  f"(share of Claude usage, model-weighted)")
        return

    if args.command == "anchor":
        run_anchor(args.force, args.json)
        return

    if args.command == "sessions":
        sessions = scan_sessions(args.max_age)
        if args.json:
            print(json.dumps({"sessions": sessions}, indent=2))
        else:
            for s in sessions:
                mins = s["age_seconds"] // 60
                title = (s.get("name") or s["project"])[:30]
                print(f"{s['session_id'][:8]}  {title:<30}  {mins}m ago")
            if not sessions:
                print("no recent sessions")
        return

    if args.command == "keepalive":
        if not args.session_id:
            print("error: --session-id required", file=sys.stderr)
            sys.exit(2)
        run_keepalive(args.session_id, args.stale_after, args.json)
        return

    if (args.command == "status" and not args.json
            and (args.live or (not args.once and sys.stdout.isatty()))):
        run_live(args)
        return

    raw, token_status, state = get_usage(args.auto_refresh)

    if args.command == "raw":
        if raw is None:
            print(f"error: {token_status}", file=sys.stderr)
            sys.exit(2)
        print(json.dumps(raw, indent=2))
        return

    if args.command == "notify":
        run_notify(raw, token_status, state, args.threshold)
        return

    if raw is None:
        hint = ("token stale — run any `claude` command once, or pass --auto-refresh"
                if token_status == "stale_token" else token_status)
        if args.command == "check":
            print("unknown")
        print(f"error: {hint}", file=sys.stderr)
        sys.exit(2)

    windows, available = build_report(raw, args.threshold, args.window)

    if args.command == "check":
        print("true" if available else "false")
        for w in windows:
            if w["blocked"]:
                print(f"limited: {w['name']} ({fmt_pct(w['percent'])} used), "
                      f"{format_reset(w)}", file=sys.stderr)
        sys.exit(0 if available else 1)

    if args.json:
        print(json.dumps({
            "available": available,
            "threshold": args.threshold,
            "checked_at": now_utc().isoformat(),
            "token_status": token_status,
            "windows": windows,
            "extra_usage_enabled": bool((raw.get("extra_usage") or {}).get("is_enabled")),
        }, indent=2))
        sys.exit(0 if available else 1)

    width = max((len(w["name"]) for w in windows), default=7)
    for w in windows:
        flag = "  ← LIMITED" if w["blocked"] else ""
        print(f"{w['name']:<{width}}  {fmt_pct(w['percent']):>5} used  "
              f"{fmt_pct(w['left']):>5} left  {format_reset(w)}{flag}")
    print(f"available: {'true' if available else 'false'}")
    sys.exit(0 if available else 1)


def session_window(raw):
    """Return the session window dict from a raw response, or None."""
    for w in normalize(raw):
        if w["name"] == "session":
            return w
    return None


def log_anchor(line):
    stamp = now_utc().strftime("%Y-%m-%dT%H:%M:%SZ")
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        with ANCHOR_LOG.open("a") as f:
            f.write(f"{stamp} {line}\n")
    except Exception:
        pass


def run_anchor(force, json_out):
    """Open a session window if none is open (or always, with force).

    Exit codes: 0 sent, 3 skipped (window already open), 4 skipped (guard),
    5 probe failed, 2 usage unreadable.
    """
    def done(status, message, code, extra=None):
        log_anchor(f"{status}: {message}")
        if json_out:
            payload = {"status": status, "message": message}
            if extra:
                payload.update(extra)
            print(json.dumps(payload))
        else:
            print(f"{status}: {message}", file=sys.stderr if code else sys.stdout)
        sys.exit(code)

    state = load_state()

    if not force:
        raw, token_status, _ = get_usage(auto_refresh=False)
        if raw is None:
            done("error", f"can't read usage ({token_status})", 2)
        sess = session_window(raw)
        # A present session entry with a future reset and nonzero usage means the
        # window is already open; anchoring again would waste a probe.
        if sess is not None and sess.get("resets_at"):
            rs = parse_iso(sess["resets_at"])
            if rs and (rs - now_utc()).total_seconds() > 0 and (sess.get("percent") or 0) > 0:
                done("skipped", f"session window already open, {format_reset(sess)}", 3,
                     {"session_percent": sess.get("percent")})
        last = state.get("last_anchor_attempt", 0)
        if now_utc().timestamp() - last < ANCHOR_GUARD_SECONDS:
            wait = int(ANCHOR_GUARD_SECONDS - (now_utc().timestamp() - last))
            done("skipped", f"anchored recently, wait {wait // 60}m", 4)

    state["last_anchor_attempt"] = now_utc().timestamp()
    save_state(state)
    ok, message = run_claude_probe()
    if not ok:
        done("error", message, 5)
    done("sent", "session window opened via cheapest-model probe", 0)


def run_notify(raw, token_status, state, threshold):
    stamp = now_utc().strftime("%Y-%m-%dT%H:%M:%SZ")
    if raw is None:
        print(f"{stamp} error: {token_status}", flush=True)
        if state.get("token_ok", True) and token_status == "stale_token":
            notify_mac("Can't read usage: token stale. Run any `claude` command once.")
        state["token_ok"] = token_status != "stale_token"
        save_state(state)
        return
    state["token_ok"] = True
    windows, available = build_report(raw, threshold, None)
    summary = " ".join(f"{w['name']}={fmt_pct(w['percent'])}" for w in windows)
    print(f"{stamp} {summary} available={'true' if available else 'false'}", flush=True)
    prev = state.get("windows", {})
    for w in windows:
        was_blocked = prev.get(w["name"])
        if was_blocked is None or was_blocked == w["blocked"]:
            continue
        if w["blocked"]:
            notify_mac(f"{w['name']} limit reached — {format_reset(w)}")
        else:
            notify_mac(f"{w['name']} limit reset — {fmt_pct(w['percent'])} used, available again")
    state["windows"] = {w["name"]: w["blocked"] for w in windows}
    state["checked_at"] = now_utc().isoformat()
    save_state(state)


if __name__ == "__main__":
    main()
